# ============================================================
# SERMUL - Variables de Entorno (Plantilla)
# Copia este archivo como .env y ajusta los valores
# ============================================================

# --- Base de Datos ---
POSTGRES_USER=sermul_user
POSTGRES_PASSWORD=tu_password_seguro
POSTGRES_DB=sermul_db

# --- Backend / JWT ---
# En producción genera una clave fuerte (ej: openssl rand -hex 32)
SECRET_KEY=tu_clave_secreta_super_segura
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- CORS (URLs permitidas separadas por coma) ---
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173
